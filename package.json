{
  "name": "avatar-animations-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "[ -f .env ] && set -a && . ./.env && set +a; next dev --turbopack -p ${PORT:-4000}",
    "build": "prisma generate && node scripts/verify-db-env.mjs && prisma migrate deploy && prisma db seed && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@prisma/client": "^6.19.0",
    "gsap": "^3.12.7",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.5.0",
    "prisma": "^6.19.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
