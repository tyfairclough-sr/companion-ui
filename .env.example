# --- Local development (docker-compose Postgres) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/companion?schema=public"
# Same as DATABASE_URL for local dev (direct connection; no pooler needed).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/companion?schema=public"

# --- Production (Neon) ---
# Pooled connection for the app at runtime (hostname includes -pooler).
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct connection for Prisma migrate deploy / db seed (no -pooler in hostname).
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Port the dev server listens on when running locally (npm run dev). Defaults to 4000.
PORT=4000
